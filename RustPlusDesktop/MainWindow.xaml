                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="8,8,0,0">
                                <Button x:Name="BtnShopToggle"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Click="BtnShopSearch_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8,8,0,0">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#30FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE721;" 
                                                   FontFamily="Segoe MDL2 Assets" 
                                                   FontSize="12" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="Shop Search" 
                                                   FontSize="11" 
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="OverlayToolbox"
        Grid.Row="1"
        Background="#CC1E1E1E"
        CornerRadius="6"
        Padding="6"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Margin="8"
        Visibility="Collapsed"
        Panel.ZIndex="9000">
                        <StackPanel>

                            <!-- Zeichnen -->
                            <Button x:Name="ToolDrawButton"
                Width="32" Height="32"
                ToolTip="Draw (Right Click: Size / Color)"
                Click="ToolDrawButton_Click"
                PreviewMouseRightButtonDown="ToolDrawButton_RightClick">
                                <Image Source="pack://application:,,,/Assets/icons/pen.png"/>
                            </Button>

                            <!-- Text -->
                            <Button x:Name="ToolTextButton"
                Width="32" Height="32"
                ToolTip="Place Text (Right Click: Color / Size)"
                Click="ToolTextButton_Click"
                PreviewMouseRightButtonDown="ToolTextButton_RightClick">
                                <Image Source="pack://application:,,,/Assets/icons/text.png"/>
                            </Button>

                            <!-- Icons -->
                            <Button x:Name="ToolIconButton"
                Width="32" Height="32"
                ToolTip="Place Icon (Right Click: Pick Icon)"
                Click="ToolIconButton_Click"
                PreviewMouseRightButtonDown="ToolIconButton_RightClick">
                                <Image Source="pack://application:,,,/Assets/icons/pin.png"/>
                            </Button>

                            <!-- Radierer -->
                            <Button x:Name="ToolEraseButton"
                Width="32" Height="32"
                ToolTip="Eraser (hold or click)"
                Click="ToolEraseButton_Click"
                PreviewMouseRightButtonDown="ToolEraseButton_RightClick">
                                <Image Source="pack://application:,,,/Assets/icons/eraser.png"/>
                            </Button>

                            <Separator/>

                            <!-- LÃ¶schen  -->
                            <Button x:Name="ToolTrashButton"
                Width="32" Height="32"
                ToolTip="Delete own overlay"
                Click="ToolTrashButton_Click">
                                <Image Source="pack://application:,,,/Assets/icons/trash.png"/>
                            </Button>

                            <!-- Upload / Teilen -->
                            <Button x:Name="ToolUploadButton"
                Width="32" Height="32"
                ToolTip="Upload own Overlay / share"
                Click="ToolUploadButton_Click">
                                <Image Source="pack://application:,,,/Assets/icons/upload.png"/>
                            </Button>

                        </StackPanel>
                    </Border>

                    <Border x:Name="OverlayTeamBar"
        Grid.Row="1"
        Background="#801E1E1E"
        CornerRadius="6"
        Padding="4"
        HorizontalAlignment="Center"
        VerticalAlignment="Bottom"
        Margin="0,0,0,8"
        Visibility="Collapsed"
        Panel.ZIndex="9000">
                        <StackPanel x:Name="OverlayTeamStack"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="4"
                >
                            <!-- Buttons fÃ¼r Team-Mitglieder werden dynamisch in CodeBehind eingefÃ¼gt -->
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBox x:Name="TxtLog" Grid.Row="2"
                         Height="100"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
        <Grid Background="#80000000"
          Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
          IsHitTestVisible="True"   
            Panel.ZIndex="9999">
            <Border Background="#F2FFFFFF" CornerRadius="8"
                Padding="20" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding BusyText}" FontSize="16" FontWeight="SemiBold"
                           TextAlignment="Center" Margin="0,0,0,10"/>
                    <ProgressBar IsIndeterminate="True" Height="6"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Background="#80000000"
      Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
      IsHitTestVisible="True"
      Panel.ZIndex="9999">
            <Border Background="{DynamicResource AccentDark}" CornerRadius="8" Padding="20"
          Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding BusyText}" FontSize="16" FontWeight="SemiBold"
                 TextAlignment="Center" Margin="0,0,0,10"/>
                    <ProgressBar IsIndeterminate="True" Height="6"/>
                </StackPanel>
            </Border>
        </Grid>


    </Grid>
</Window>
    
